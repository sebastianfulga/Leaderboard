@page "/leaderboard"
@using LeaderboardApp.Models
@using LeaderboardApp.Services
@inject ILeaderboardService LeaderboardService

<PageTitle>Leaderboard</PageTitle>

<section class="leaderboard-page">
    <header class="leaderboard-header">
        <div>
            <p class="eyebrow">Season rankings</p>
            <h1>Leaderboard</h1>
            <p class="header-copy">Top competitors ranked by total score, recent form, and match results.</p>
        </div>

        <div class="header-stats" aria-label="Leaderboard summary">
            <div>
                <span class="stat-value">1,000</span>
                <span class="stat-label">Athletes</span>
            </div>
            <div>
                <span class="stat-value">42</span>
                <span class="stat-label">Events</span>
            </div>
            <div>
                <span class="stat-value">97.8</span>
                <span class="stat-label">Top rating</span>
            </div>
        </div>
    </header>

    <div class="leaderboard-toolbar" aria-label="Leaderboard controls">
        <div class="ranking-tabs" role="tablist" aria-label="Ranking views">
            <button class="active" type="button">Overall</button>
            <button type="button">Sprint</button>
            <button type="button">Endurance</button>
            <button type="button">Team</button>
        </div>

        <div class="season-pill">
            <span class="season-dot" aria-hidden="true"></span>
            2026 regular season
        </div>
    </div>

    <section class="podium" aria-label="Top three competitors">
        @foreach (var entry in TopThree)
        {
            <article class="podium-card rank-@entry.Rank">
                <div class="rank-badge">#@entry.Rank</div>
                <div class="athlete-mark">@entry.Initials</div>
                <div>
                    <h2>@entry.Name</h2>
                    <p>@entry.Team</p>
                </div>
                <strong>@entry.Score.ToString("N0") pts</strong>
                <span>@entry.Record</span>
            </article>
        }
    </section>

    <section class="leaderboard-board" aria-label="Full leaderboard">
        <div class="board-header">
            <div>Rank</div>
            <div>Competitor</div>
            <div>Rating</div>
            <div>Record</div>
            <div>Points</div>
            <div>Form</div>
        </div>

        <div class="board-rows">
            @foreach (var entry in Rankings)
            {
                <article class="board-row">
                    <div class="rank-cell">
                        <span class="rank-number">@entry.Rank</span>
                        <span class="rank-change @(entry.Change >= 0 ? "up" : "down")">
                            @(entry.Change >= 0 ? "+" : "")@entry.Change
                        </span>
                    </div>

                    <div class="competitor-cell">
                        <span class="avatar">@entry.Initials</span>
                        <span>
                            <strong>@entry.Name</strong>
                            <small>@entry.Team</small>
                        </span>
                    </div>

                    <div class="rating-cell">
                        <span>@entry.Rating.ToString("0.0")</span>
                        <div class="rating-track" aria-hidden="true">
                            <span style="width: @entry.RatingPercent%"></span>
                        </div>
                    </div>

                    <div>@entry.Record</div>
                    <div class="points-cell">@entry.Score.ToString("N0")</div>
                    <div>
                        <span class="form-chip">@entry.Form</span>
                    </div>
                </article>
            }
        </div>
    </section>
</section>

@code {
    private IReadOnlyList<LeaderboardEntry> Rankings { get; set; } = [];

    private IEnumerable<LeaderboardEntry> TopThree => Rankings.Take(3);

    protected override async Task OnInitializedAsync()
    {
        Rankings = await LeaderboardService.GetRankingsAsync();
    }
}
