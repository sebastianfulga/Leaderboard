@page "/leaderboard"
@rendermode InteractiveServer
@implements IDisposable
@using LeaderboardApp.Models
@using LeaderboardApp.Services
@inject ILeaderboardService LeaderboardService

<PageTitle>Leaderboard</PageTitle>

<section class="leaderboard-page">
    <header class="leaderboard-header">
        <div>
            <p class="eyebrow">Season rankings</p>
            <h1>Leaderboard</h1>
            <p class="header-copy">Top competitors ranked by total score, recent form, and match results.</p>
        </div>

        <div class="header-stats" aria-label="Leaderboard summary">
            <div>
                <span class="stat-value">1,000</span>
                <span class="stat-label">Athletes</span>
            </div>
            <div>
                <span class="stat-value">42</span>
                <span class="stat-label">Events</span>
            </div>
            <div>
                <span class="stat-value">97.8</span>
                <span class="stat-label">Top rating</span>
            </div>
        </div>
    </header>

    <div class="leaderboard-toolbar" aria-label="Leaderboard controls">
        <div class="ranking-tabs" role="tablist" aria-label="Ranking views">
            <button class="active" type="button">Overall</button>
            <button type="button">Sprint</button>
            <button type="button">Endurance</button>
            <button type="button">Team</button>
        </div>

        <div class="toolbar-actions">
            <label class="search-box">
                <span class="visually-hidden">Search competitors</span>
                <svg aria-hidden="true" viewBox="0 0 24 24">
                    <path d="m21 21-4.35-4.35m2.35-5.65a8 8 0 1 1-16 0 8 8 0 0 1 16 0Z" />
                </svg>
                <input type="search"
                       placeholder="Search competitors"
                       autocomplete="off"
                       @bind="SearchText"
                       @bind:event="oninput"
                       @bind:after="SearchAsync" />
            </label>

            <div class="season-pill">
                <span class="season-dot" aria-hidden="true"></span>
                2026 regular season
            </div>
        </div>
    </div>

    <section class="podium" aria-label="Top three competitors">
        @foreach (var entry in TopThree)
        {
            <article class="podium-card rank-@entry.Rank">
                <div class="rank-badge">#@entry.Rank</div>
                <div class="athlete-mark">@entry.Initials</div>
                <div>
                    <h2>@entry.Name</h2>
                    <p>@entry.Team</p>
                </div>
                <strong>@entry.Score.ToString("N0") pts</strong>
                <span>@entry.Record</span>
            </article>
        }
    </section>

    <section class="leaderboard-board" aria-label="Full leaderboard" aria-busy="@IsLoading.ToString().ToLowerInvariant()">
        <div class="board-header">
            <div>Rank</div>
            <div>Competitor</div>
            <div>Rating</div>
            <div>Record</div>
            <div>Points</div>
            <div>Form</div>
        </div>

        <div class="board-rows" @key="ResultsVersion">
            @if (Rankings.Count == 0)
            {
                <div class="no-results" role="status">
                    No competitors found for “@SearchText.Trim()”.
                </div>
            }
            else
            {
                @foreach (var entry in Rankings)
                {
                    <article class="board-row">
                        <div class="rank-cell">
                            <span class="rank-number">@entry.Rank</span>
                            <span class="rank-change @(entry.Change >= 0 ? "up" : "down")">
                                @(entry.Change >= 0 ? "+" : "")@entry.Change
                            </span>
                        </div>

                        <div class="competitor-cell">
                            <span class="avatar">@entry.Initials</span>
                            <span>
                                <strong>@entry.Name</strong>
                                <small>@entry.Team</small>
                            </span>
                        </div>

                        <div class="rating-cell">
                            <span>@entry.Rating.ToString("0.0")</span>
                            <div class="rating-track" aria-hidden="true">
                                <span style="width: @entry.RatingPercent%"></span>
                            </div>
                        </div>

                        <div>@entry.Record</div>
                        <div class="points-cell">@entry.Score.ToString("N0")</div>
                        <div>
                            <span class="form-chip">@entry.Form</span>
                        </div>
                    </article>
                }
            }
        </div>

        @if (TotalCount > 0)
        {
            <footer class="pagination-bar" aria-label="Leaderboard pagination">
                <p>
                    Showing <strong>@FirstVisibleItem–@LastVisibleItem</strong>
                    of <strong>@TotalCount.ToString("N0")</strong> competitors
                </p>

                <div class="pagination-controls">
                    <button type="button"
                            disabled="@(IsLoading || CurrentPage == 1)"
                            @onclick="ShowPreviousPageAsync">
                        Previous
                    </button>
                    <span>Page <strong>@CurrentPage</strong> of <strong>@TotalPages</strong></span>
                    <button type="button"
                            disabled="@(IsLoading || CurrentPage == TotalPages)"
                            @onclick="ShowNextPageAsync">
                        Next
                    </button>
                </div>
            </footer>
        }
    </section>
</section>

@code {
    private const int PageSize = 500;

    private IReadOnlyList<LeaderboardEntry> Rankings { get; set; } = [];

    private IReadOnlyList<LeaderboardEntry> TopThree { get; set; } = [];

    private string SearchText { get; set; } = string.Empty;

    private int CurrentPage { get; set; } = 1;

    private int TotalCount { get; set; }

    private int TotalPages { get; set; }

    private int ResultsVersion { get; set; }

    private bool IsLoading { get; set; }

    private CancellationTokenSource? queryCancellation;

    private int FirstVisibleItem => ((CurrentPage - 1) * PageSize) + 1;

    private int LastVisibleItem => Math.Min(CurrentPage * PageSize, TotalCount);

    protected override Task OnInitializedAsync() => LoadPageAsync();

    private async Task SearchAsync()
    {
        CurrentPage = 1;
        await LoadPageAsync();
    }

    private async Task ShowPreviousPageAsync()
    {
        if (CurrentPage <= 1)
        {
            return;
        }

        CurrentPage--;
        await LoadPageAsync();
    }

    private async Task ShowNextPageAsync()
    {
        if (CurrentPage >= TotalPages)
        {
            return;
        }

        CurrentPage++;
        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        var previousCancellation = queryCancellation;
        var currentCancellation = new CancellationTokenSource();
        queryCancellation = currentCancellation;
        previousCancellation?.Cancel();

        IsLoading = true;

        try
        {
            var page = await LeaderboardService.GetRankingsAsync(
                new LeaderboardQuery(CurrentPage, PageSize, SearchText),
                currentCancellation.Token);

            if (currentCancellation != queryCancellation)
            {
                return;
            }

            Rankings = page.Items;
            TotalCount = page.TotalCount;
            TotalPages = page.TotalPages;
            ResultsVersion++;

            if (TopThree.Count == 0 && CurrentPage == 1 && string.IsNullOrWhiteSpace(SearchText))
            {
                TopThree = page.Items.Take(3).ToList();
            }
        }
        catch (OperationCanceledException) when (currentCancellation.IsCancellationRequested)
        {
        }
        finally
        {
            if (currentCancellation == queryCancellation)
            {
                queryCancellation = null;
                IsLoading = false;
            }

            currentCancellation.Dispose();
        }
    }

    public void Dispose()
    {
        queryCancellation?.Cancel();
        queryCancellation = null;
    }
}
